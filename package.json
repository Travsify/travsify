{
  "name": "travsify-monorepo",
  "version": "1.0.0",
  "description": "Travsify Unified Travel API Platform",
  "scripts": {
    "backend:dev": "npm run start:dev --prefix backend",
    "frontend:dev": "npm run dev --prefix frontend",
    "start:dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "install:all": "npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
