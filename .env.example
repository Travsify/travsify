# --- CORE CONFIG ---
NODE_ENV=production
PORT=3001
JWT_SECRET= (Auto-generated by Render Blueprint)
JWT_EXPIRATION=24h

# --- DATABASE ---
# Render will provide the DATABASE_URL automatically when deploying via render.yaml
# DATABASE_URL=

# --- FLIGHTS (NDC XML.AGENCY) ---
NDC_API_SEARCH_URL=https://api.xml.agency/AirShopping
NDC_API_ACTION_URL=https://api.xml.agency/OrderCreate
NDC_API_LOGIN=your_xml_agency_login
NDC_API_PASS=your_xml_agency_password
NDC_API_TOKEN=your_xml_agency_token
NDC_API_DEVICE_ID=your_device_id
DUFFEL_API_KEY=duffel_live_...

# --- HOTELS (LITEAPI) ---
LITEAPI_API_KEY=lite_...

# --- TOURS (GETYOURGUIDE) ---
GETYOURGUIDE_API_KEY=gyg_...
GYG_PARTNER_ID=travsify

# --- TRANSFERS (MOZIO) ---
MOZIO_API_KEY=mozio_...
MOZIO_AFFILIATE_ID=travsify

# --- INSURANCE (SAFETYWING) ---
SAFETYWING_PARTNER_ID=26515160

# --- PAYMENTS & WALLET ---
FINCRA_API_KEY=fincra_live_...
STRIPE_SECRET_KEY=sk_live_...
